{
  "name": "@configshape/yaml-json-patcher",
  "version": "0.1.0",
  "description": "Parse, query, and patch YAML, JSON, TOML and XML with comment preservation",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jq": {
      "types": "./dist/engines/jq.d.ts",
      "import": "./dist/engines/jq.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "size-limit": "size-limit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "@iarna/toml": "^2.2.5",
    "@jmespath-community/jmespath": "^1.3.0",
    "fast-json-patch": "^3.1.1",
    "fast-xml-parser": "^5.2.5",
    "jsonpath-plus": "^10.3.0",
    "jq-wasm": "^1.1.0-jq-1.8.1",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@size-limit/file": "^11.2.0",
    "size-limit": "^11.2.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  },
  "size-limit": [
    {
      "name": "core",
      "path": "dist/index.js",
      "limit": "90 KB",
      "gzip": true
    }
  ]
}
